    "name": "知识点名称",
    "vertex_type": "concept",
    "sub_type": "子类型",
    "description": "简要描述",
    "properties": {
      "difficulty": "中等",
      "importance": "高",
      "tags": ["标签1", "标签2"]
    }
  }
]

